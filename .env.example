BACKEND_HOST=127.0.0.1
BACKEND_PORT=8300
FRONTEND_PORT=3100
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8300
APP_VERSION=development
APP_ENV=development
BACKEND_INSTANCE_COUNT=1
LOG_LEVEL=INFO

MYSQL_IMAGE=mysql:8.4
MYSQL_PORT=13306
MYSQL_DATABASE=auto_reign
MYSQL_USER=auto_reign
MYSQL_PASSWORD=auto_reign
MYSQL_ROOT_PASSWORD=auto_reign_root
DATABASE_URL=mysql+pymysql://auto_reign:auto_reign@127.0.0.1:13306/auto_reign

QDRANT_IMAGE=qdrant/qdrant:v1.17.0
QDRANT_HTTP_PORT=16333
QDRANT_GRPC_PORT=16334
QDRANT_URL=http://127.0.0.1:16333
QDRANT_COLLECTION=auto_reign_default
QDRANT_API_KEY=

ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.19.3
ELASTICSEARCH_PORT=19200
ELASTICSEARCH_URL=http://127.0.0.1:19200
ELASTICSEARCH_INDEX=auto_reign_knowledge
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_REQUEST_TIMEOUT_SECONDS=30

DATA_DIR=./data
INIT_DATA_DIR=./init_data
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=10080

OBJECT_STORE_BACKEND=local
OBJECT_STORE_LOCAL_ROOT=
OBJECT_STORE_MAX_READ_BYTES=33554432
S3_ENDPOINT_URL=
S3_BUCKET=
S3_NAMESPACE_APP_EXCLUSIVE=false
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_KEY_PREFIX=
S3_ADDRESSING_STYLE=virtual

ATTACHMENT_MAX_BYTES=20971520
ATTACHMENT_MAX_PARSED_CHARS=1000000
ATTACHMENT_MAX_DECOMPRESSED_BYTES=33554432
ATTACHMENT_MAX_PDF_PAGES=500
AGENT_HOME_MAX_FILE_BYTES=1000000
KNOWLEDGE_DOCUMENT_MAX_BYTES=20971520
KNOWLEDGE_MAX_PARSED_CHARS=2000000
KNOWLEDGE_MAX_DECOMPRESSED_BYTES=67108864
KNOWLEDGE_MAX_PDF_PAGES=1000
KNOWLEDGE_WORKER_PROCESSING_TIMEOUT_SECONDS=300
KNOWLEDGE_WORKER_POLL_INTERVAL_SECONDS=1.0
KNOWLEDGE_MAX_RESULTS=10
KNOWLEDGE_MAX_QUERY_CHARS=2000
CHAT_CONTEXT_TOKEN_BUDGET=32000
TOOL_RESULT_TOKEN_RESERVE=4096
IMAGE_INPUT_TOKEN_RESERVE=4096
MODEL_REQUEST_TIMEOUT_SECONDS=30.0
RUNTIME_MAX_TOOL_ROUNDS=8

