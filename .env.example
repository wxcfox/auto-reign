BACKEND_HOST=127.0.0.1
BACKEND_PORT=8300
FRONTEND_PORT=3100
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8300

MYSQL_IMAGE=mysql:8.4
MYSQL_PORT=13306
MYSQL_DATABASE=auto_reign
MYSQL_USER=auto_reign
MYSQL_PASSWORD=auto_reign
MYSQL_ROOT_PASSWORD=auto_reign_root
DATABASE_URL=mysql+pymysql://auto_reign:auto_reign@127.0.0.1:13306/auto_reign

QDRANT_IMAGE=qdrant/qdrant:v1.17.0
QDRANT_HTTP_PORT=16333
QDRANT_GRPC_PORT=16334
QDRANT_URL=http://127.0.0.1:16333
QDRANT_COLLECTION=auto_reign_default

DATA_DIR=./data

EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=text-embedding-v4

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

OPENAI_CHAT_MODELS=gpt-4.1-mini,gpt-4.1
DEEPSEEK_CHAT_MODELS=deepseek-chat
QWEN_CHAT_MODELS=qwen3.7-plus,qwen3.7-max

DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

DETERMINISTIC_MODEL_FALLBACK=false
