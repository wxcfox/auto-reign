BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATA_DIR=/app/data
SQLITE_PATH=/app/data/app.db
CHROMA_DIR=/app/data/chroma
DEFAULT_COLLECTION=default
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# Backend-only provider credentials. Never expose these as NEXT_PUBLIC variables.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_CHAT_MODELS=gpt-4.1-mini,gpt-4.1
DEEPSEEK_CHAT_MODELS=deepseek-chat
QWEN_CHAT_MODELS=qwen-plus,qwen-max
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Enable only for automated tests or an explicitly offline local demo.
DETERMINISTIC_MODEL_FALLBACK=false
# Browser-visible API URL. This value is embedded during the frontend build.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
