# Release image coordinates. Production deploys must use an exact MAJOR.MINOR.PATCH version.
ACR_REGISTRY=replace-with-your-acr-vpc-endpoint
ACR_NAMESPACE=replace-with-your-acr-namespace
AUTO_REIGN_VERSION=0.1.0

# Host Nginx proxies these loopback-only ports. Do not bind them to 0.0.0.0.
AUTO_REIGN_BACKEND_PORT=18300
AUTO_REIGN_FRONTEND_PORT=13100

# Persistent host paths. Keep these outside the Git checkout.
AUTO_REIGN_DATA_DIR=/srv/auto-reign/data
AUTO_REIGN_MYSQL_DIR=/srv/auto-reign/mysql
AUTO_REIGN_QDRANT_DIR=/srv/auto-reign/qdrant
AUTO_REIGN_BACKUP_DIR=/srv/auto-reign/backups
AUTO_REIGN_STATE_DIR=/srv/auto-reign

# The first object-storage release is intentionally one backend process and one
# exclusive S3-compatible namespace. Alibaba Cloud OSS uses virtual-hosted style.
APP_ENV=production
BACKEND_INSTANCE_COUNT=1
LOG_LEVEL=INFO
OBJECT_STORE_BACKEND=s3
OBJECT_STORE_MAX_READ_BYTES=33554432
S3_ENDPOINT_URL=https://oss-cn-hangzhou.aliyuncs.com
S3_BUCKET=replace-with-your-exclusive-bucket
S3_NAMESPACE_APP_EXCLUSIVE=true
S3_REGION=cn-hangzhou
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_KEY_PREFIX=auto-reign-production
S3_ADDRESSING_STYLE=virtual

# Infrastructure images are pinned independently from the application release.
MYSQL_IMAGE=mysql:8.4
QDRANT_IMAGE=qdrant/qdrant:v1.17.0

MYSQL_DATABASE=auto_reign
MYSQL_USER=auto_reign
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-another-long-random-password
JWT_SECRET_KEY=replace-with-openssl-rand-base64-48-output

ACCESS_TOKEN_EXPIRE_MINUTES=10080
QDRANT_COLLECTION=auto_reign_default

# Application safety and context limits. Compose supplies DATA_DIR, DATABASE_URL,
# QDRANT_URL and APP_VERSION; the remaining settings below are explicit so
# production does not rely on hidden code defaults.
OBJECT_STORE_MAX_READ_BYTES=33554432
ATTACHMENT_MAX_BYTES=20971520
ATTACHMENT_MAX_PARSED_CHARS=1000000
ATTACHMENT_MAX_DECOMPRESSED_BYTES=33554432
ATTACHMENT_MAX_PDF_PAGES=500
AGENT_HOME_MAX_FILE_BYTES=1000000
KNOWLEDGE_DOCUMENT_MAX_BYTES=20971520
KNOWLEDGE_MAX_PARSED_CHARS=2000000
KNOWLEDGE_MAX_DECOMPRESSED_BYTES=67108864
KNOWLEDGE_MAX_PDF_PAGES=1000
KNOWLEDGE_WORKER_PROCESSING_TIMEOUT_SECONDS=300
KNOWLEDGE_WORKER_POLL_INTERVAL_SECONDS=1.0
KNOWLEDGE_MAX_RESULTS=30
KNOWLEDGE_MAX_QUERY_CHARS=2000
CHAT_CONTEXT_TOKEN_BUDGET=32000
TOOL_RESULT_TOKEN_RESERVE=4096
IMAGE_INPUT_TOKEN_RESERVE=4096
MODEL_REQUEST_TIMEOUT_SECONDS=30.0
RUNTIME_MAX_TOOL_ROUNDS=8

EMBEDDING_PROVIDER=qwen
EMBEDDING_MODEL=text-embedding-v4
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_CHAT_MODELS=gpt-4.1-mini,gpt-4.1
DEEPSEEK_CHAT_MODELS=deepseek-chat
QWEN_CHAT_MODELS=qwen3.7-plus,qwen3.7-max
DEFAULT_CHAT_PROVIDER=qwen
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional public probe executed after internal container health checks.
DEPLOY_HEALTHCHECK_URL=https://auto-reign.example.com
