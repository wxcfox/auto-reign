{$AUTO_REIGN_SITE_ADDRESS} {
	encode zstd gzip

	@api path /api/*
	handle @api {
		reverse_proxy backend:8000 {
			flush_interval -1
		}
	}

	handle {
		reverse_proxy frontend:3000
	}

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options DENY
	}

	log {
		output stdout
		format json
	}
}
